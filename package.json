{
  "name": "uhaul-migration-tracker",
  "version": "1.0.0",
  "description": "U-Haul one-way pricing as real-time Bay Area migration proxy",
  "private": true,
  "type": "module",
  "scripts": {
    "collect": "tsx src/collector.ts",
    "collect:headed": "tsx src/collector.ts --headed",
    "serve": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "vitest run",
    "posttest": "git rev-parse HEAD > .test-passed",
    "lint": "eslint src/",
    "validate-docs": "node scripts/validate-docs.cjs --full",
    "prepare": "husky"
  },
  "dependencies": {
    "express": "^4.21.0",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
